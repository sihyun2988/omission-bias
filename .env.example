# ─────────────────────────────────────────────────────────────────
# .env.example
#
# 사용법:
#   1. cp .env.example .env
#   2. 아래 값들 실제로 채우기
#   3. ENABLED_MODELS 에 사용할 모델만 콤마로 나열
#
# 모델 정의(이름/provider/logprobs/json_mode)는 src/models.py 참고.
# ─────────────────────────────────────────────────────────────────

# 활성 모델 (콤마 구분)
# 사용 가능: qwen3.5-9b, qwen-vllm, openrouter
ENABLED_MODELS=qwen3.5-9b

# OpenAI
OPENAI_API_KEY=sk-...

# 자체 호스팅 vLLM (OpenAI 호환 엔드포인트)
#   vllm serve <model> --port 8000
VLLM_BASE_URL=http://210.222.65.89:8100/v1
VLLM_API_KEY=...
VLLM_MODEL_NAME=qwen/qwen3.5-9b

# OpenRouter (OpenAI 호환 엔드포인트)
OPENROUTER_BASE_URL=https://api.ssunlp.co.kr/v1
OPENROUTER_API_KEY=...
OPENROUTER_MODEL_NAME=qwen/qwen3.5-9b
